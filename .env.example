# ─── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://ebenesaid_user:your_secure_password@localhost:5432/ebenesaid_db

# ─── Firebase ──────────────────────────────────────────────────────────────────
# All values are in your Firebase Console → Project Settings → General
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── AI / Google Genkit ────────────────────────────────────────────────────────
# Get this from Google AI Studio: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your-google-genai-api-key

# ─── OpenAI (optional — used as fallback) ──────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ─── Next.js ───────────────────────────────────────────────────────────────────
NODE_ENV=production
# The public URL where the platform will be accessible (no trailing slash)
NEXT_PUBLIC_APP_URL=https://yourdomain.com
PORT=3000
